{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue", "vite.config.ts"],
  "exclude": [
    "src/components/notifications/**",
    "src/layouts/dashboard/vertical-sidebar/NavCollapse/**",
    "src/layouts/dashboard/vertical-sidebar/NavGroup/**",
    "src/layouts/dashboard/vertical-sidebar/NavItem/**",
    "src/layouts/dashboard/vertical-sidebar/extrabox/**",
    "src/layouts/dashboard/vertical-sidebar/RecursiveMenu.vue",
    "src/layouts/dashboard/vertical-header/ProfileDD.vue",
    "src/views/dashboard/maj/**"
  ]
}
